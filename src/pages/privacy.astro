---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = 'Privacy Policy | Iorl - WhatChar';
const description = 'Privacy policy for Iorl - WhatChar, a browser-based Unicode character checker.';

const contactEmail = 'contact@isitiorl.com';
---

<BaseLayout title={title} description={description} lang="en" locale="en" path="/privacy/">
  <header class="topbar">
    <a class="brand" href="/" aria-label="Iorl - WhatChar home">Iorl - WhatChar</a>
  </header>

  <main class="page-shell">
    <section class="seo-copy legal-page">
      <h1>Privacy Policy</h1>

      <p><strong>Last updated:</strong> June 2026</p>

      <h2>Overview</h2>
      <p>
        Iorl - WhatChar is a browser-based tool for identifying confusing Unicode characters,
        lookalike characters, mixed scripts, and invisible spaces.
      </p>

      <h2>Text analysis</h2>
      <p>
        The text you paste into Iorl - WhatChar is analyzed locally in your browser.
        It is not sent to our server for analysis.
      </p>

      <h2>Hosting and technical logs</h2>
      <p>
        The site may be hosted through infrastructure providers such as Cloudflare.
        These providers may process standard technical information such as IP address,
        user agent, request URL, referrer, and timestamps for security, performance,
        abuse prevention, and diagnostic purposes.
      </p>

      <h2>Cookies</h2>
      <p>
        Iorl - WhatChar does not currently require account cookies or login cookies.
        If analytics, advertising, or other third-party services are added later,
        this policy will be updated to explain how those services use cookies or similar technologies.
      </p>

      <h2>Advertising</h2>
      <p>
        Iorl - WhatChar does not currently display ads. If advertising services such as
        Google AdSense are added in the future, third-party vendors may use cookies or
        similar technologies to serve and measure ads. This policy will be updated before
        such advertising is enabled.
      </p>

      <h2>Contact</h2>
      <p>
        If you have questions about this privacy policy, contact us at
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
      </p>
    </section>
  </main>

  <footer class="footer">
    <span><a href="/">Home</a></span>
    <span><a href="/about/">About</a></span>
    <span><a href="/contact/">Contact</a></span>
  </footer>
</BaseLayout>